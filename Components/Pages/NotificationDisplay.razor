@page "/notifications"
@rendermode InteractiveServer
@inject Application_06.Services.NotificationService NotificationService
@inject Application_06.Models.NotificationConfig Config

<div class="d-flex justify-content-between align-items-center my-4">
    <div>
        <h2 class="fw-bold mb-0 text-dark">Notification Center</h2>
        <p class="text-muted mb-0">
            Current Mode: <span class="badge bg-primary text-uppercase">@Config.NotificationStyle</span>
        </p>
    </div>
    <button class="btn btn-outline-primary rounded-pill px-4" @onclick="RefreshNotifications">
        <i class="bi bi-arrow-clockwise me-1"></i> Refresh
    </button>
</div>

@if (notifications == null)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!notifications.Any())
{
    <div class="text-center my-5 py-5 border rounded-3 bg-light">
        <i class="bi bi-bell-slash text-muted fs-1 d-block mb-2"></i>
        <p class="text-muted mb-0">No notifications found.</p>
    </div>
}
else
{
    <div class="notification-container">
        @foreach (var item in notifications)
        {
            var badgeClass = item.Type switch
            {
                "Success" => "bg-success-subtle border-success text-success",
                "Warning" => "bg-warning-subtle border-warning text-warning",
                _ => "bg-info-subtle border-info text-info"
            };

            var iconClass = item.Type switch
            {
                "Success" => "bi-check-circle-fill text-success",
                "Warning" => "bi-exclamation-triangle-fill text-warning",
                _ => "bi-info-circle-fill text-info"
            };

            @if (Config.NotificationStyle == "Compact")
            {
                <div class="card mb-2 border-start border-4 @badgeClass shadow-sm py-2 px-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-3">
                            <i class="bi @iconClass fs-5"></i>
                            <span class="fw-semibold text-dark">@item.Title</span>
                        </div>
                        <small class="text-muted font-monospace">@item.Timestamp.ToString("HH:mm")</small>
                    </div>
                </div>
            }
            else
            {
                <div class="card mb-3 border-start border-4 @badgeClass shadow-sm p-3">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <h5 class="card-title fw-bold text-dark mb-0 d-flex align-items-center gap-2">
                            <i class="bi @iconClass"></i>
                            @item.Title
                        </h5>
                        <small class="text-muted font-monospace">@item.Timestamp.ToShortTimeString()</small>
                    </div>
                    <p class="card-text text-secondary mb-0 mt-2">@item.Message</p>
                </div>
            }
        }
    </div>
}

@code {
    private List<Application_06.Services.NotificationItem>? notifications;

    protected override async Task OnParametersSetAsync()
    {
        await RefreshNotifications();
    }

    private async Task RefreshNotifications()
    {
        notifications = null;
        notifications = await NotificationService.GetNotificationsAsync(Config.DefaultNumberOfNotifications);
    }
}